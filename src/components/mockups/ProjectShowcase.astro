---
interface ProjectCard {
	name: string;
	summary: string;
	stack: string;
}

interface Props {
	title: string;
	description: string;
	caseStudyLabel: string;
	cards: ProjectCard[];
}

const { title, description, caseStudyLabel, cards } = Astro.props;
---

<section id="projects" class="rounded-3xl border border-brand-border bg-brand-surface p-8 sm:p-10">
	<h2 class="text-2xl font-semibold text-brand-text sm:text-3xl">{title}</h2>
	<p class="mt-3 max-w-2xl text-sm leading-6 text-brand-muted">
		{description}
	</p>

	<div class="mt-7 flex flex-col gap-4">
		{
			cards.map((project, index) => (
				<article
					class:list={[
						"rounded-2xl border bg-brand-bg-alt p-5 transition hover:-translate-y-0.5",
						index === 0 ? "border-brand-accent-violet/50" : index === 1 ? "border-brand-accent-cyan/40" : "border-brand-border",
					]}
				>
					<p class="text-xs font-semibold uppercase tracking-[0.12em] text-brand-subtle">
						{project.stack}
					</p>
					<h3 class="mt-3 text-lg font-semibold text-brand-text">{project.name}</h3>
					<p class="mt-2 text-sm leading-6 text-brand-muted">{project.summary}</p>
					<p class="mt-5 text-xs font-semibold uppercase tracking-[0.12em] text-brand-accent-cyan">
						{caseStudyLabel}
					</p>
				</article>
			))
		}
	</div>
</section>
