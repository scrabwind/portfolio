---
interface Props {
	title: string;
	summary: string;
	skillsTitle: string;
	skills: string[];
	languagesTitle: string;
	languages: string[];
}

const { title, summary, skillsTitle, skills, languagesTitle, languages } = Astro.props;
---

<section id="profile" class="rounded-3xl border border-brand-border bg-brand-surface p-8 sm:p-10">
	<h2 class="text-2xl font-semibold text-brand-text sm:text-3xl">{title}</h2>
	<div class="mt-7 space-y-4">
		<article class="rounded-2xl border border-brand-border bg-brand-bg-alt p-5 sm:p-6">
			<p class="text-sm leading-7 text-brand-muted">{summary}</p>
		</article>

		<article class="rounded-2xl border border-brand-border bg-brand-bg-alt p-5 sm:p-6">
			<h3 class="text-lg font-semibold text-brand-text">{skillsTitle}</h3>
			<ul class="mt-4 flex flex-wrap gap-2">
				{
					skills.map((skill) => (
						<li class="rounded-full border border-brand-border bg-brand-surface px-3 py-1 text-xs font-medium text-brand-muted">
							{skill}
						</li>
					))
				}
			</ul>
		</article>

		<article class="rounded-2xl border border-brand-border bg-brand-bg-alt p-5 sm:p-6">
			<h3 class="text-lg font-semibold text-brand-text">{languagesTitle}</h3>
			<ul class="mt-3 space-y-2">
				{
					languages.map((language) => (
						<li class="text-sm text-brand-muted">{language}</li>
					))
				}
			</ul>
		</article>
	</div>
</section>
