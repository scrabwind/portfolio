---
const stack = ["JavaScript", "TypeScript", "React", "Astro", "Accessibility"];
---

<section class="relative overflow-hidden rounded-3xl border border-brand-border bg-brand-surface p-8 sm:p-10">
	<div
		aria-hidden="true"
		class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-[radial-gradient(circle,_rgba(180,95,255,0.5)_0%,_rgba(99,240,227,0.16)_42%,_transparent_72%)] blur-2xl"
	/>
	<div class="relative max-w-3xl">
		<p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-accent-cyan">
			Dark Theme Mockup
		</p>
		<h1 class="mt-4 text-4xl font-semibold tracking-tight text-brand-text sm:text-5xl">
			Hi, I build polished interfaces for the web.
		</h1>
		<p class="mt-5 max-w-2xl text-base leading-7 text-brand-muted">
			This hero block demonstrates how the new color tokens look with layered surfaces, high contrast
			typography, and subtle neon accents inspired by your reference screenshots.
		</p>
		<div class="mt-8 flex flex-wrap gap-3">
			<a
				href="#projects"
				class="rounded-full border border-brand-accent-cyan bg-brand-accent-cyan/10 px-5 py-2.5 text-sm font-medium text-brand-text transition hover:bg-brand-accent-cyan/20"
			>
				View projects
			</a>
			<a
				href="#experience"
				class="rounded-full border border-brand-border bg-brand-bg-alt px-5 py-2.5 text-sm font-medium text-brand-muted hover:text-brand-text"
			>
				Read experience
			</a>
		</div>
		<ul class="mt-7 flex flex-wrap gap-2">
			{
				stack.map((item) => (
					<li class="rounded-full border border-brand-border bg-brand-bg-alt px-3 py-1 text-xs font-medium text-brand-muted">
						{item}
					</li>
				))
			}
		</ul>
	</div>
</section>
