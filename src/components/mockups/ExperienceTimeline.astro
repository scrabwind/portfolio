---
interface ExperienceRole {
	years: string;
	title: string;
	company: string;
	description: string;
	tags: string[];
}

interface Props {
	title: string;
	timelineLabel: string;
	roles: ExperienceRole[];
}

const { title, timelineLabel, roles } = Astro.props;
---

<section id="experience" class="rounded-3xl border border-brand-border bg-brand-surface p-8 sm:p-10">
	<div class="flex items-center justify-between gap-4">
		<h2 class="text-2xl font-semibold text-brand-text sm:text-3xl">{title}</h2>
		<span class="hidden text-xs font-medium uppercase tracking-[0.15em] text-brand-subtle sm:block">
			{timelineLabel}
		</span>
	</div>
	<div class="mt-8 space-y-5">
		{
			roles.map((role) => (
				<article class="rounded-2xl border border-brand-border bg-brand-bg-alt p-5 sm:p-6">
					<div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
						<p class="text-xs font-semibold uppercase tracking-[0.12em] text-brand-subtle">
							{role.years}
						</p>
						<h3 class="text-lg font-semibold text-brand-text">
							{role.title}
							<span class="text-brand-muted"> - {role.company}</span>
						</h3>
					</div>
					<p class="mt-3 text-sm leading-6 text-brand-muted">{role.description}</p>
					<ul class="mt-4 flex flex-wrap gap-2">
						{
							role.tags.map((tag) => (
								<li class="rounded-full border border-brand-border bg-brand-surface px-2.5 py-1 text-xs text-brand-muted">
									{tag}
								</li>
							))
						}
					</ul>
				</article>
			))
		}
	</div>
</section>
