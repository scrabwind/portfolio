---
import { ClientRouter } from "astro:transitions";
import type { SupportedLocale } from "../i18n/home";

const fallbackLocale: SupportedLocale = Astro.currentLocale === "pl" ? "pl" : "en";
---

<!doctype html>
<html lang={fallbackLocale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Redirecting...</title>
		<meta http-equiv="refresh" content={`0;url=/${fallbackLocale}/`} />
    <ClientRouter />
		<script is:inline define:vars={{ fallbackLocale }}>
			(() => {
				const localeStorageKey = "preferred-locale";

				const normalizeLocale = (value) => {
					if (typeof value !== "string") return null;

					const lower = value.toLowerCase();
					if (lower === "pl" || lower.startsWith("pl-")) return "pl";
					if (lower === "en" || lower.startsWith("en-")) return "en";

					return null;
				};

				const storedLocale = (() => {
					try {
						return localStorage.getItem(localeStorageKey);
					} catch {
						return null;
					}
				})();

				const normalizedStoredLocale = storedLocale ? normalizeLocale(storedLocale) : null;
				const preferredBrowserLocale =
					navigator.languages?.map(normalizeLocale).find((locale) => locale !== null) ??
					normalizeLocale(navigator.language);
				const targetLocale =
					normalizedStoredLocale ??
					preferredBrowserLocale ??
					fallbackLocale;
				const safeTargetLocale = targetLocale === "pl" ? "pl" : "en";

				window.location.replace(`/${safeTargetLocale}/`);
			})();
		</script>
	</head>
	<body>
		<p>Redirecting...</p>
	</body>
</html>
